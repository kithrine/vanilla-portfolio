{
  "doctype-first": true,
  "doctype-html5": true,
  "title-require": true,
  "attr-no-duplication": true,
  "id-unique": true,
  "src-not-empty": true,
  "alt-require": true,
  "spec-char-escape": true,
  "attr-unsafe-chars": true,
  "style-disabled": false,
  "inline-style-disabled": false,
  "id-class-value": false
}
